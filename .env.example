# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` to version control.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Variables without the prefix are server-only.
# =============================================================================

# --- Site Configuration ---
# Override the canonical URL (defaults to https://ameysawant.in in constants)
# NEXT_PUBLIC_SITE_URL=https://ameysawant.in

# --- Analytics (Future) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS=true

# --- Contact Form (Future) ---
# Used for server-side email sending (e.g., Resend, SendGrid)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=amey123sawant@gmail.com

# --- CMS / Content (Future) ---
# If a headless CMS is added for blog or project content
# CMS_API_URL=
# CMS_API_TOKEN=

# --- Error Reporting (Future) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
